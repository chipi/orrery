{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fleet-index.schema.json",
  "title": "FleetIndex",
  "description": "Summary records for all fleet entries. static/data/fleet/index.json per PRD-012 v0.2 / RFC-016 v0.2 OQ-1 (option C: index + per-entry detail).",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "category",
      "agency",
      "country",
      "era",
      "epoch",
      "status",
      "first_flight",
      "tagline"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
        "minLength": 2
      },
      "name": { "type": "string", "minLength": 1 },
      "category": {
        "type": "string",
        "enum": [
          "launcher",
          "crewed-spacecraft",
          "cargo-spacecraft",
          "station",
          "rover",
          "lander",
          "orbiter",
          "observatory",
          "space-suit"
        ]
      },
      "agency": { "type": "string", "minLength": 1 },
      "country": { "type": "string", "minLength": 1 },
      "era": {
        "type": "string",
        "enum": ["1957-1969", "1969-1981", "1981-2011", "2011-now", "planned"]
      },
      "epoch": {
        "type": "string",
        "enum": [
          "first-steps",
          "space-race",
          "lunar-era",
          "first-stations",
          "shuttle-and-mir",
          "iss-assembly",
          "commercial-era",
          "lunar-return",
          "mars-era"
        ]
      },
      "status": {
        "type": "string",
        "enum": ["FLOWN", "ACTIVE", "RETIRED", "FAILED", "PLANNED"]
      },
      "first_flight": {
        "oneOf": [
          { "type": "string", "format": "date" },
          { "type": "string", "pattern": "^[0-9]{4}$" },
          { "type": "string", "enum": ["planned"] }
        ]
      },
      "hero_path": {
        "type": "string",
        "description": "Optional hero photo path under static/images/fleet/. Populated in Phase D."
      },
      "tagline": { "type": "string", "minLength": 1, "maxLength": 140 }
    }
  }
}
