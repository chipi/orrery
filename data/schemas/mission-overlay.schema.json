{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mission-overlay.schema.json",
  "title": "MissionOverlay",
  "description": "Editorial overlay per mission per locale (ADR-017, ADR-020). One file per mission per locale at data/i18n/[locale]/missions/[dest]/[id].json. Merged with the base record at fetch time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "first", "description", "events"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "first": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["met", "label", "note", "type"],
        "properties": {
          "met": { "type": "number", "minimum": 0 },
          "label": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 },
          "type": { "enum": ["nominal", "info", "warning"] }
        }
      }
    }
  }
}
