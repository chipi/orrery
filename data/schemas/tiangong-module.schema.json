{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tiangong-module.schema.json",
  "title": "TiangongModules",
  "description": "Tiangong pressurised modules + Chinarm. Base tiangong-modules.json per ADR-017 / PRD-011 / ADR-049.",
  "type": "array",
  "minItems": 4,
  "maxItems": 4,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "builder",
      "builder_country",
      "agency",
      "launch_vehicle",
      "launch_date",
      "flight_designation",
      "mass_kg",
      "length_m",
      "status",
      "credit",
      "links"
    ],
    "properties": {
      "id": {
        "type": "string",
        "enum": ["tianhe", "wentian", "mengtian", "chinarm"]
      },
      "builder": { "type": "string", "minLength": 1 },
      "builder_country": { "type": "string", "minLength": 1 },
      "agency": { "type": "string", "minLength": 1 },
      "launch_vehicle": { "type": "string", "minLength": 1 },
      "launch_date": { "type": "string", "format": "date" },
      "flight_designation": { "type": "string", "minLength": 1 },
      "mass_kg": { "type": "number", "exclusiveMinimum": 0 },
      "length_m": { "type": "number", "minimum": 0 },
      "year_first_of": { "type": "string", "minLength": 1 },
      "status": { "type": "string", "enum": ["ACTIVE", "RETIRED"] },
      "credit": { "type": "string", "minLength": 1 },
      "links": {
        "type": "array",
        "minItems": 2,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["l", "u", "t"],
          "properties": {
            "l": { "type": "string", "minLength": 1 },
            "u": { "type": "string", "format": "uri" },
            "t": { "type": "string", "enum": ["intro", "core", "deep"] }
          }
        }
      }
    }
  }
}
