{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fleet-entry.schema.json",
  "title": "FleetEntry",
  "description": "Per-entry detail file under static/data/fleet/{category}/{id}.json. Hardware family inventory record per PRD-012 v0.2 / RFC-016 v0.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "category",
    "agency",
    "country",
    "manufacturer",
    "first_flight",
    "status",
    "era",
    "epoch",
    "credit",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2
    },
    "name": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "launcher",
        "crewed-spacecraft",
        "cargo-spacecraft",
        "station",
        "rover",
        "lander",
        "orbiter",
        "observatory"
      ]
    },
    "agency": { "type": "string", "minLength": 1 },
    "country": { "type": "string", "minLength": 1 },
    "manufacturer": { "type": "string", "minLength": 1 },
    "first_flight": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "string", "pattern": "^[0-9]{4}$" },
        { "type": "string", "enum": ["planned"] }
      ]
    },
    "last_flight": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "string", "pattern": "^[0-9]{4}$" }
      ]
    },
    "status": {
      "type": "string",
      "enum": ["FLOWN", "ACTIVE", "RETIRED", "FAILED", "PLANNED"]
    },
    "era": {
      "type": "string",
      "enum": ["1957-1969", "1969-1981", "1981-2011", "2011-now", "planned"]
    },
    "epoch": {
      "type": "string",
      "enum": [
        "first-steps",
        "space-race",
        "lunar-era",
        "first-stations",
        "shuttle-and-mir",
        "iss-assembly",
        "commercial-era",
        "lunar-return"
      ]
    },
    "best_known_for": { "type": "string" },
    "specs": {
      "type": "object",
      "description": "Category-specific specs; permissive shape, validated per category in validate-data.ts.",
      "additionalProperties": {
        "oneOf": [
          { "type": "number" },
          { "type": "string" },
          { "type": "boolean" }
        ]
      }
    },
    "linked_missions": {
      "type": "array",
      "description": "Mission IDs from missions/index.json. Curated explicitly per RFC-016 OQ-2.",
      "items": { "type": "string", "minLength": 1 }
    },
    "linked_sites": {
      "type": "array",
      "description": "Reverse pointers to surface markers / orbital objects. Populated in Phase K.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "site_id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["moon", "mars", "earth-object"]
          },
          "site_id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "flights": {
      "type": "array",
      "description": "Notable flights (3-6 per crewed-spacecraft entry per RFC-016 OQ-11).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mission_id", "flight_designation"],
        "properties": {
          "mission_id": { "type": "string", "minLength": 1 },
          "flight_designation": { "type": "string", "minLength": 1 },
          "patch_path": { "type": "string" },
          "crew": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "role"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "minLength": 1 },
                "agency": { "type": "string" },
                "country": { "type": "string" },
                "portrait_path": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "explorer_route": {
      "type": "string",
      "description": "Optional route to dedicated explorer (e.g., '/iss', '/tiangong'). Renders 'Open Explorer →' CTA in OVERVIEW per RFC-016 OQ-12.",
      "pattern": "^/[a-z][a-z0-9-]*$"
    },
    "credit": { "type": "string", "minLength": 1 },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["l", "u", "t"],
        "properties": {
          "l": { "type": "string", "minLength": 1 },
          "u": { "type": "string", "format": "uri" },
          "t": { "type": "string", "enum": ["intro", "core", "deep"] }
        }
      }
    }
  }
}
