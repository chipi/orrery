{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "iss-module.schema.json",
  "title": "IssModules",
  "description": "ISS pressurised modules + Canadarm2. Base iss-modules.json per ADR-017 / PRD-010.",
  "type": "array",
  "minItems": 18,
  "maxItems": 18,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "builder",
      "builder_country",
      "agency",
      "launch_vehicle",
      "launch_date",
      "flight_designation",
      "mass_kg",
      "length_m",
      "status",
      "credit",
      "links"
    ],
    "properties": {
      "id": {
        "type": "string",
        "enum": [
          "beam",
          "canadarm2",
          "columbus",
          "cupola",
          "destiny",
          "harmony",
          "kibo",
          "leonardo",
          "nauka",
          "pirs",
          "poisk",
          "prichal",
          "quest",
          "rassvet",
          "tranquility",
          "unity",
          "zarya",
          "zvezda"
        ]
      },
      "builder": { "type": "string", "minLength": 1 },
      "builder_country": { "type": "string", "minLength": 1 },
      "agency": { "type": "string", "minLength": 1 },
      "launch_vehicle": { "type": "string", "minLength": 1 },
      "launch_date": { "type": "string", "format": "date" },
      "flight_designation": { "type": "string", "minLength": 1 },
      "mass_kg": { "type": "number", "exclusiveMinimum": 0 },
      "length_m": { "type": "number", "minimum": 0 },
      "year_first_of": { "type": "string", "minLength": 1 },
      "status": { "type": "string", "enum": ["ACTIVE", "RETIRED"] },
      "credit": { "type": "string", "minLength": 1 },
      "links": {
        "type": "array",
        "minItems": 2,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["l", "u", "t"],
          "properties": {
            "l": { "type": "string", "minLength": 1 },
            "u": { "type": "string", "format": "uri" },
            "t": { "type": "string", "enum": ["intro", "core", "deep"] }
          }
        }
      }
    }
  }
}
