{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mission.schema.json",
  "title": "Mission",
  "description": "Base mission record (language-neutral) per ADR-020. One file per mission at data/missions/[dest]/[id].json. v0.1.7 (ADR-027) extends with optional flight + flight_data_quality fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "agency",
    "agency_full",
    "sector",
    "dest",
    "color",
    "year",
    "status",
    "departure_date",
    "arrival_date",
    "transit_days",
    "vehicle",
    "payload",
    "delta_v",
    "data_quality",
    "credit",
    "links"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "agency": { "type": "string", "minLength": 1 },
    "agency_full": { "type": "string", "minLength": 1 },
    "sector": { "enum": ["gov", "private"] },
    "dest": { "enum": ["MARS", "MOON"] },
    "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
    "year": { "type": "integer", "minimum": 1957, "maximum": 2100 },
    "status": { "enum": ["ACTIVE", "FLOWN", "PLANNED"] },
    "departure_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO 8601 date of launch (UTC)"
    },
    "arrival_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO 8601 date of Mars arrival (orbit insertion or landing as appropriate). For PLANNED missions, use the current NET (no-earlier-than) target."
    },
    "transit_days": { "type": "integer", "minimum": 0 },
    "vehicle": { "type": "string", "minLength": 1 },
    "payload": { "type": "string", "minLength": 1 },
    "delta_v": {
      "type": "string",
      "pattern": "^~?\\d+(\\.\\d+)?\\s*km/s(\\s*\\([^)]+\\))?$",
      "description": "Total mission ∆v in km/s. Tilde prefix marks an estimate; an optional annotation in parens (e.g., \"(round trip)\", \"(TLI only)\") is allowed. Schema enforces the format so /fly's parseDeltaV() helper has no malformed input to guard against."
    },
    "data_quality": { "enum": ["good", "partial", "reconstructed"] },
    "credit": { "type": "string", "minLength": 1 },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["l", "u", "t"],
        "properties": {
          "l": { "type": "string", "minLength": 1 },
          "u": { "type": "string", "format": "uri" },
          "t": { "enum": ["intro", "core", "deep"] }
        }
      }
    },
    "flight_data_quality": {
      "enum": ["measured", "reconstructed", "sparse", "unknown"],
      "description": "Honesty flag (ADR-027). measured = full public records (NASA press kit, JPL TR); reconstructed = post-hoc engineering reconstruction; sparse = fragmentary public records; unknown = data not yet researched or mission not flown."
    },
    "flight": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured flight parameters per ADR-027. Every sub-object is optional; missing = unknown (renders as em-dash in the UI).",
      "properties": {
        "launch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "vehicle_stage": { "type": "string", "minLength": 1 },
            "c3_km2_s2": { "type": "number", "minimum": 0, "maximum": 200 },
            "declination_deg": { "type": "number", "minimum": -90, "maximum": 90 },
            "mass_at_tli_kg": { "type": "number", "minimum": 0, "maximum": 500000 },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "cruise": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tcm_count": { "type": "integer", "minimum": 0, "maximum": 30 },
            "peak_heliocentric_speed_km_s": { "type": "number", "minimum": 0, "maximum": 100 },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "arrival": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "v_infinity_km_s": { "type": "number", "minimum": 0, "maximum": 50 },
            "entry_velocity_km_s": { "type": "number", "minimum": 0, "maximum": 50 },
            "periapsis_km": { "type": ["number", "null"], "minimum": 0, "maximum": 1000000 },
            "inclination_deg": { "type": ["number", "null"], "minimum": 0, "maximum": 180 },
            "orbit_insertion_dv_km_s": { "type": ["number", "null"], "minimum": 0, "maximum": 20 },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total_dv_km_s": { "type": "number", "minimum": 0, "maximum": 50 },
            "tli_or_tmi_dv_km_s": { "type": "number", "minimum": 0, "maximum": 20 },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["met_days", "type"],
            "properties": {
              "met_days": { "type": "number", "minimum": 0 },
              "type": {
                "enum": [
                  "launch",
                  "tli_or_tmi",
                  "tcm",
                  "arrival",
                  "edl_or_oi",
                  "flyby",
                  "earth_return",
                  "anomaly"
                ]
              }
            }
          }
        }
      }
    }
  }
}
