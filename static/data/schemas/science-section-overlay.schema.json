{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "science-section-overlay.schema.json",
  "title": "ScienceSectionOverlay",
  "description": "Editorial overlay per /science section per locale (ADR-017).",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "intro_sentence", "body_paragraphs"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "intro_sentence": { "type": "string", "minLength": 1, "maxLength": 240 },
    "body_paragraphs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "narrative_101": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 1 },
      "description": "Conversational lead-in that expands the matching landing-page chapter."
    },
    "formula_caption": { "type": "string", "minLength": 1 },
    "diagram_caption": { "type": "string", "minLength": 1 }
  }
}
